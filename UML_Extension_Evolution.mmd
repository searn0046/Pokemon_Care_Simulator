classDiagram
    class Pokemon {
        <<abstract>>
        +name: str
        +species: str
        +type: str
        +stage: int
        +next_stage: type|None
        +nutrition: int
        +energy: int
        +happiness: int
        +level: int
        +age: int
        +curr_mood: str
        +update(ticks_passed, framerate)
        +set_mood()
        +give_energy()
        +feed()
        +play()
        +sleep()
        +wake_up()
        +level_up()
        +evolve()
        +die()
    }

    class FireType { <<abstract>> }
    class WaterType { <<abstract>> }
    class ElectricType { <<abstract>> }
    class RockType { <<abstract>> }

    Pokemon <|-- FireType
    Pokemon <|-- WaterType
    Pokemon <|-- ElectricType
    Pokemon <|-- RockType

    class Charmander
    class Charmeleon
    class Charizard
    FireType <|-- Charmander
    FireType <|-- Charmeleon
    FireType <|-- Charizard
    Charmander --> Charmeleon : next_stage
    Charmeleon --> Charizard : next_stage

